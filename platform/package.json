{
  "name": "magic-english-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "npm run dev -w @magic-english/web",
    "dev:api": "npm run dev -w @magic-english/api",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "db:generate": "npm run db:generate -w @magic-english/api",
    "db:migrate": "npm run db:migrate -w @magic-english/api",
    "db:seed": "npm run db:seed -w @magic-english/api",
    "db:studio": "npm run db:studio -w @magic-english/api"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
